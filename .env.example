# Helius RPC URL (required)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# PostgreSQL connection string (required)
POSTGRES_URL=postgres://indexer:changeme@localhost:5432/solana_indexer

# ClickHouse connection string (required)
CLICKHOUSE_URL=http://localhost:9000

# Solana program ID to index (required)
PROGRAM_ID=YourProgramPubkeyHere

# Optional: start slot (if not set, starts from latest indexed or earliest available)
START_SLOT=

# Optional: end slot (if not set, indexes indefinitely)
END_SLOT=

# Batch size for fetching transactions (default 100)
BATCH_SIZE=100

# Path to IDL JSON file (optional, if not set, fetches from on-chain account)
IDL_PATH=