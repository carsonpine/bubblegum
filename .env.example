# Helius RPC URL (required)
# Get your API key at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Solana program public key to index (required)
# This should be the Anchor program's program ID
PROGRAM_ID=YourProgramPubkeyHere

# PostgreSQL connection string (required for Docker)
POSTGRES_URL=postgres://indexer:changeme@postgres:5432/solana_indexer

# ClickHouse connection (required for Docker)
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=indexer
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DB=solana_indexer

# Slot range (optional - defaults to last 1000 slots from current)
# START_SLOT=200000000
# END_SLOT=200001000

# Batch size for slot processing (1-1000, default: 100)
BATCH_SIZE=100

# IDL source: path to JSON file or "account" for on-chain fetch (default: account)
# IDL_PATH=/app/idl.json
IDL_PATH=account

# API server port (default: 3000)
API_PORT=3000

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# RPC rate limit (free Helius tier: 10, paid: up to 100)
RPC_RATE_LIMIT=10

# PostgreSQL max connections (default: 10)
DB_MAX_CONNECTIONS=10

# ClickHouse batch insert size (default: 1000)
CH_BATCH_SIZE=1000

# Environment: dev (pretty logs) or production (JSON logs)
RUST_ENV=dev

# For Docker Compose: mount your local IDL file if using file-based IDL
# IDL_FILE=./idl.json
